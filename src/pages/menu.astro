---
import BaseLayout from '../layouts/BaseLayout.astro';
import MenuHero from '../sections/MenuHero.astro';
import MenuGrid from '../components/MenuGrid';
import OrderFlowCallout from '../sections/OrderFlowCallout.astro';
import OrderCTA from '../sections/OrderCTA.astro';
---

<BaseLayout
  title="The Menu | Lamb Shepherd Restaurant | Xinjiang Chinese-Muslim Cuisine"
  description="Browse our halal menu of authentic Xinjiang dishes. Roast lamb ribs, hand-pulled noodles, dumplings with chili oil, and more. Desa Setapak, KL."
  canonical="/menu"
>
  <MenuHero />
  <MenuGrid client:load />
  <OrderFlowCallout />
  <OrderCTA />
</BaseLayout>
