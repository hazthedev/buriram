---
import Container from '../components/Container.astro';
---

<section class="pt-32 pb-16 lg:pt-40 lg:pb-20 bg-soft-cream">
  <Container>
    <div class="max-w-3xl">
      <span class="inline-block text-xs font-semibold uppercase tracking-[0.2em] text-thai-chili-red mb-4">
        Our Story
      </span>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-semibold text-deep-indigo leading-tight">
        We named ourselves after a province.
      </h1>
      <p class="mt-6 text-lg text-dusty-slate max-w-xl leading-relaxed">
        Buriram, northeast Thailand. Isan country. Where the somtum is real, the larb is fresh, and the grilled meats come straight off the flame. The food we serve learned to walk there.
      </p>
    </div>
  </Container>
</section>
