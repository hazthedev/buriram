---
import Container from '../components/Container.astro';
---

<section class="pt-32 pb-16 lg:pt-40 lg:pb-20 bg-warm-sand">
  <Container>
    <div class="max-w-3xl">
      <span class="inline-block text-xs font-semibold uppercase tracking-[0.2em] text-xinjiang-red mb-4">
        Our Story
      </span>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-semibold text-charred-brown leading-tight">
        Xinjiang is over 5,000km away. The flavors aren't.
      </h1>
      <p class="mt-6 text-lg text-earth-brown max-w-xl leading-relaxed">
        Northwest China. Silk Road country. Where lamb is king and cumin is the second seasoning after salt. We bring those flavors to Desa Setapak — halal, authentic, and worth the drive.
      </p>
    </div>
  </Container>
</section>
