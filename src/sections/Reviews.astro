---
import Container from '../components/Container.astro';
import FadeUp from '../components/FadeUp';
import reviewsData from '../data/reviews.json';
---

<section class="py-20 lg:py-28 bg-warm-sand">
  <Container>
    <FadeUp client:visible>
      <div class="text-center mb-12">
        <p class="font-display text-2xl sm:text-3xl text-charred-brown">
          4.8 <span class="text-xinjiang-red">/</span> 5 from regulars who know.
        </p>
        <p class="text-sm text-earth-brown mt-2">Tripadvisor · Google · Facebook · 2,392 likes</p>
      </div>
    </FadeUp>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8 max-w-5xl mx-auto">
      {reviewsData.reviews.map((review, index) => (
        <FadeUp client:visible delay={index * 0.15}>
          <div class="bg-pure-cream rounded-xl p-6 lg:p-8 border border-charred-brown/5 h-full">
            <div class="flex gap-1 mb-4">
              {Array.from({ length: review.rating }).map(() => (
                <svg class="w-4 h-4 text-saffron" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-charred-brown leading-relaxed mb-4">"{review.text}"</p>
            <div class="flex items-center justify-between text-sm">
              <span class="font-medium text-charred-brown">{review.author}</span>
              <span class="text-earth-brown/60">{review.source}</span>
            </div>
          </div>
        </FadeUp>
      ))}
    </div>
  </Container>
</section>
