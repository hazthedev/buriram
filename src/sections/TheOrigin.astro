---
import Container from '../components/Container.astro';
import FadeUp from '../components/FadeUp';
---

<section class="py-20 lg:py-28 bg-pure-cream">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <FadeUp client:visible delay={0.2}>
          <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-warm-sand">
            <img
              src="/images/origin.svg"
              alt="Chef preparing Xinjiang lamb dishes"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </FadeUp>
      </div>
      <div>
        <FadeUp client:visible>
          <span class="inline-block text-xs font-semibold uppercase tracking-[0.2em] text-xinjiang-red mb-3">The Beginning</span>
          <h2 class="font-display text-3xl sm:text-4xl font-semibold text-charred-brown leading-tight">
            Chinese-Muslim cuisine in KL.
          </h2>
          <div class="mt-6 space-y-4 text-earth-brown leading-relaxed max-w-lg">
            <p>
              Lamb Shepherd has been serving authentic Xinjiang cuisine in Desa Setapak since at least 2016. No flashy signage, no hype — just honest food that speaks for itself.
            </p>
            <p>
              We chose this neighborhood because it's where our community lives. Chinese Muslims who grew up on these flavors, who know the difference between real cumin-spiced lamb and the imitation stuff.
            </p>
            <p>
              Most of our regulars are Chinese Muslims. That's how you know it's the real thing. The food hasn't changed. The regulars haven't changed. We just renovated the interior — looks more upmarket now, but the soul is the same.
            </p>
          </div>
        </FadeUp>
      </div>
    </div>
  </Container>
</section>
