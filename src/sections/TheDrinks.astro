---
import Container from '../components/Container.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FadeUp from '../components/FadeUp';
---

<section class="py-20 lg:py-28 bg-pure-cream">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <FadeUp client:visible>
          <SectionHeading
            title="And don't skip the hawthorn plum drink."
          />
          <div class="mt-6 space-y-6">
            <div class="flex gap-4">
              <div class="w-12 h-12 rounded-full bg-xinjiang-red/10 flex items-center justify-center shrink-0">
                <span class="text-lg">🫐</span>
              </div>
              <div>
                <h3 class="font-display text-lg font-semibold text-charred-brown">Hawthorn Plum <span lang="zh" class="font-zh text-sm">山楂梅子</span></h3>
                <p class="text-sm text-earth-brown">Sweet-tart, chilled, cuts through lamb richness perfectly. The signature drink — don't skip this.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-12 h-12 rounded-full bg-cumin-gold/10 flex items-center justify-center shrink-0">
                <span class="text-lg">🍵</span>
              </div>
              <div>
                <h3 class="font-display text-lg font-semibold text-charred-brown">Jasmine Tea <span lang="zh" class="font-zh text-sm">茉莉花茶</span></h3>
                <p class="text-sm text-earth-brown">Fragrant, hot or iced. The classic Chinese-Muslim dining companion.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-12 h-12 rounded-full bg-silk-road-indigo/10 flex items-center justify-center shrink-0">
                <span class="text-lg">🥛</span>
              </div>
              <div>
                <h3 class="font-display text-lg font-semibold text-charred-brown">Fresh Soy Milk <span lang="zh" class="font-zh text-sm">豆浆</span></h3>
                <p class="text-sm text-earth-brown">Freshly made, warm or cold. Smooth, nutty, comforting.</p>
              </div>
            </div>
          </div>
        </FadeUp>
      </div>
      <div>
        <FadeUp client:visible delay={0.2}>
          <div class="aspect-square rounded-2xl overflow-hidden bg-warm-sand">
            <img
              src="/images/hawthorn-plum.svg"
              alt="Hawthorn plum drink in a glass"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </FadeUp>
      </div>
    </div>
  </Container>
</section>
