---
import Container from '../components/Container.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FadeUp from '../components/FadeUp';
---

<section class="py-20 lg:py-28 bg-pure-cream">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <FadeUp client:visible>
          <SectionHeading
            title="Plus the drinks that pair."
          />
          <div class="mt-6 space-y-6">
            <div class="flex gap-4">
              <div class="w-12 h-12 rounded-full bg-thai-chili-red/10 flex items-center justify-center shrink-0">
                <span class="text-lg">🧋</span>
              </div>
              <div>
                <h3 class="font-display text-lg font-semibold text-deep-indigo">Thai Milk Tea</h3>
                <p class="text-sm text-dusty-slate">Strong, creamy, sweet. The classic antidote to chili heat.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-12 h-12 rounded-full bg-lemongrass-green/10 flex items-center justify-center shrink-0">
                <span class="text-lg">🍵</span>
              </div>
              <div>
                <h3 class="font-display text-lg font-semibold text-deep-indigo">Thai Green Tea</h3>
                <p class="text-sm text-dusty-slate">Lighter, fragrant, with a hint of vanilla.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="w-12 h-12 rounded-full bg-ceramic-blue/10 flex items-center justify-center shrink-0">
                <span class="text-lg">🍋</span>
              </div>
              <div>
                <h3 class="font-display text-lg font-semibold text-deep-indigo">Lime Soda</h3>
                <p class="text-sm text-dusty-slate">Fresh lime, soda, ice. Simple and essential.</p>
              </div>
            </div>
          </div>
        </FadeUp>
      </div>
      <div>
        <FadeUp client:visible delay={0.2}>
          <div class="aspect-square rounded-2xl overflow-hidden bg-soft-cream">
            <img
              src="/images/drinks.svg"
              alt="Thai milk tea and lime soda on a table"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </FadeUp>
      </div>
    </div>
  </Container>
</section>
