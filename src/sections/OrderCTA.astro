---
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
---

<section class="py-16 lg:py-20 bg-pure-cream">
  <Container>
    <div class="max-w-xl mx-auto text-center space-y-6">
      <h2 class="font-display text-3xl sm:text-4xl font-semibold text-deep-indigo">
        Hungry?
      </h2>
      <p class="text-dusty-slate">
        WhatsApp us — for table holds, larger group orders, or to ask if today's somtum is fiery.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-2">
        <Button href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER || '60128331059'}`} variant="primary">
          WhatsApp Us
        </Button>
        <Button href="/story#visit" variant="outline">
          Visit Us
        </Button>
      </div>
    </div>
  </Container>
</section>
