---
import Container from '../components/Container.astro';
---

<section class="pt-32 pb-16 lg:pt-40 lg:pb-20 bg-soft-cream">
  <Container>
    <div class="max-w-2xl mx-auto text-center">
      <span class="inline-block text-xs font-semibold uppercase tracking-[0.2em] text-thai-chili-red mb-4">
        The Menu
      </span>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-semibold text-deep-indigo leading-tight">
        Small bowls,<br />big variety.
      </h1>
      <p class="mt-4 text-lg text-dusty-slate">
        Order three, share five. Mix and match the way Thai-Chinese dining was meant to be.
      </p>
    </div>
  </Container>
</section>
