---
import Container from '../components/Container.astro';
---

<section class="pt-32 pb-16 lg:pt-40 lg:pb-20 bg-warm-sand">
  <Container>
    <div class="max-w-2xl mx-auto text-center">
      <span class="inline-block text-xs font-semibold uppercase tracking-[0.2em] text-xinjiang-red mb-4">
        The Menu
      </span>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-semibold text-charred-brown leading-tight">
        Xinjiang flavors,<br />halal always.
      </h1>
      <p class="mt-4 text-lg text-earth-brown">
        Roast lamb ribs, hand-pulled noodles, dumplings with chili oil. Order what the regulars order.
      </p>
    </div>
  </Container>
</section>
