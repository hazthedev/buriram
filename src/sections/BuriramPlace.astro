---
import Container from '../components/Container.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FadeUp from '../components/FadeUp';
---

<section class="py-20 lg:py-28 bg-pure-cream">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div>
        <FadeUp client:visible delay={0.2}>
          <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-warm-sand">
            <img
              src="/images/xinjiang-landscape.svg"
              alt="Silk Road landscape of Xinjiang, northwest China"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </FadeUp>
      </div>
      <div>
        <FadeUp client:visible>
          <SectionHeading
            eyebrow="Where Xinjiang Meets Setapak"
            title="The flavors traveled 5,000 kilometers."
          />
          <div class="mt-6 space-y-4 text-earth-brown leading-relaxed max-w-lg">
            <p>
              Xinjiang is in northwest China — Silk Road country, where lamb is king and cumin is the second seasoning after salt. We bring those flavors here, halal-certified, served the way our community eats them every day.
            </p>
            <p>
              Most of our regulars are Chinese Muslims. The food is the proof. You don't need to travel to Urumqi to taste authentic Xinjiang cuisine — it's right here, tucked between car workshops in Desa Setapak.
            </p>
            <p class="text-sm text-earth-brown/70">
              Northern Chinese cuisine is bolder, smokier, and more spice-forward than the Cantonese food most Malaysians know.
            </p>
          </div>
        </FadeUp>
      </div>
    </div>
  </Container>
</section>
