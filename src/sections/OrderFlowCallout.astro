---
import Container from '../components/Container.astro';
---

<section class="py-16 lg:py-20 bg-warm-sand">
  <Container>
    <div class="max-w-2xl mx-auto bg-pure-cream rounded-2xl p-8 lg:p-10 border border-charred-brown/5 text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-xinjiang-red mb-3">A note from us</p>
      <h2 class="font-display text-2xl sm:text-3xl font-semibold text-charred-brown mb-4">
        How to order at Lamb Shepherd
      </h2>
      <p class="text-earth-brown leading-relaxed max-w-lg mx-auto">
        Start with the roast lamb ribs — it's why people drive across KL for this place. Add dumplings with chili oil, a beef dish, and don't skip the hawthorn plum drink. Share everything. That's how we eat.
      </p>
    </div>
  </Container>
</section>
