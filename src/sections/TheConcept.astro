---
import Container from '../components/Container.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FadeUp from '../components/FadeUp';
---

<section class="py-20 lg:py-28 bg-warm-sand">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="order-2 lg:order-1">
        <FadeUp client:visible>
          <SectionHeading
            eyebrow="The Specialty"
            title="Lamb done eight ways."
          />
          <div class="mt-6 space-y-4 text-earth-brown leading-relaxed max-w-lg">
            <p>
              Roast ribs (our showstopper). Short ribs (tender, full of soul). Lamb chops (perfectly seasoned). Lamb in noodles, in soup, in dumplings, in fried rice.
            </p>
            <p class="font-display text-xl italic text-charred-brown">
              We're called Lamb Shepherd for a reason — but the beef is excellent too.
            </p>
            <p>
              Every dish is halal, every spice is intentional. Cumin is the second seasoning after salt — that's the Xinjiang way.
            </p>
          </div>
        </FadeUp>
      </div>
      <div class="order-1 lg:order-2">
        <FadeUp client:visible delay={0.2}>
          <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-pure-cream">
            <img
              src="/images/lamb-specialty.svg"
              alt="Assortment of lamb dishes on a table"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </FadeUp>
      </div>
    </div>
  </Container>
</section>
