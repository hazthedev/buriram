---
import Container from '../components/Container.astro';
import SectionHeading from '../components/SectionHeading.astro';
import FadeUp from '../components/FadeUp';
---

<section class="py-20 lg:py-28 bg-soft-cream">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="order-2 lg:order-1">
        <FadeUp client:visible>
          <SectionHeading
            eyebrow="Why Small Bowls"
            title="Small bowls. Big choices."
          />
          <div class="mt-6 space-y-4 text-dusty-slate leading-relaxed max-w-lg">
            <p>
              Most Thai meals come in big plates that fill up fast. We do it differently — small bowls, real flavors, ordered like dim sum.
            </p>
            <p class="font-display text-xl italic text-deep-indigo">
              Pick four. Share five. Try everything.
            </p>
            <p>
              It's the best of both worlds: the boldness of Thai cuisine, the shareability of Chinese small-plate dining. No more choosing just one dish.
            </p>
          </div>
        </FadeUp>
      </div>
      <div class="order-1 lg:order-2">
        <FadeUp client:visible delay={0.2}>
          <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-pure-cream">
            <img
              src="/images/concept-bowls.svg"
              alt="Multiple small Thai bowls arranged for sharing"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </FadeUp>
      </div>
    </div>
  </Container>
</section>
