---
import Container from '../components/Container.astro';
import FadeUp from '../components/FadeUp';
---

<section class="py-20 lg:py-28 bg-soft-cream">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="order-2 lg:order-1">
        <FadeUp client:visible>
          <span class="inline-block text-xs font-semibold uppercase tracking-[0.2em] text-thai-chili-red mb-3">The Province</span>
          <h2 class="font-display text-3xl sm:text-4xl font-semibold text-deep-indigo leading-tight">
            Isan — the northeast heart of Thailand.
          </h2>
          <div class="mt-6 space-y-4 text-dusty-slate leading-relaxed max-w-lg">
            <p>
              Isan food is Thailand's best-kept secret. It's louder, sharper, and more unapologetic than Bangkok-style Thai. More lime. More chili. More smoke.
            </p>
            <p>
              Buriram province sits in the heart of Isan — a land of rice paddies, ancient Khmer temples, and open-fire grilling. The food there is built for farmers: bold flavors, simple presentation, zero pretense.
            </p>
            <p>
              We bring that same spirit to Wangsa Maju. No fusion confusion — just real Isan flavors, served in a way that makes sense for sharing.
            </p>
          </div>
        </FadeUp>
      </div>
      <div class="order-1 lg:order-2">
        <FadeUp client:visible delay={0.2}>
          <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-pure-cream">
            <img
              src="/images/isan-landscape.svg"
              alt="Rural Isan landscape with rice fields and traditional houses"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </FadeUp>
      </div>
    </div>
  </Container>
</section>
