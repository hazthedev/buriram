---
import Container from '../components/Container.astro';
import FadeUp from '../components/FadeUp';
---

<section class="py-20 lg:py-28 bg-warm-sand">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class="order-2 lg:order-1">
        <FadeUp client:visible>
          <span class="inline-block text-xs font-semibold uppercase tracking-[0.2em] text-xinjiang-red mb-3">The Region</span>
          <h2 class="font-display text-3xl sm:text-4xl font-semibold text-charred-brown leading-tight">
            Xinjiang — Silk Road country.
          </h2>
          <div class="mt-6 space-y-4 text-earth-brown leading-relaxed max-w-lg">
            <p>
              Northwest China. Vast deserts, snow-capped mountains, and a culinary heritage shaped by centuries of trade along the Silk Road. Lamb is king here. Cumin is the second seasoning after salt.
            </p>
            <p>
              Xinjiang cuisine is unlike anything else in China — it's Central Asian in spirit, with influences from Uyghur, Kazakh, and Hui cooking traditions. Deep-fried lamb, hand-pulled noodles, smoky chili oil, flatbreads baked in clay ovens.
            </p>
            <p>
              We bring that heritage to KL. Every dish is halal. Every spice is intentional. The flavors traveled 5,000 kilometers — they're worth the trip.
            </p>
          </div>
        </FadeUp>
      </div>
      <div class="order-1 lg:order-2">
        <FadeUp client:visible delay={0.2}>
          <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-pure-cream">
            <img
              src="/images/xinjiang-landscape.svg"
              alt="Xinjiang landscape with mountains and desert"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </FadeUp>
      </div>
    </div>
  </Container>
</section>
