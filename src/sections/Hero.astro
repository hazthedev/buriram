---
import Button from '../components/Button.astro';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/hero-lamb-ribs.svg"
      alt="Roast lamb ribs sizzling on a grill"
      class="w-full h-full object-cover"
      style="animation: heroSettle 1s ease-out forwards;"
    />
    <div class="absolute inset-0 bg-warm-sand/70"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">
    <div class="max-w-3xl mx-auto space-y-8">
      <!-- Eyebrow -->
      <p class="text-xs sm:text-sm font-semibold uppercase tracking-[0.25em] text-xinjiang-red">
        Desa Setapak <span class="mx-2">·</span> Chinese-Muslim <span class="mx-2">·</span> Halal <span class="mx-2">·</span> <span lang="zh" class="font-zh">中国穆斯林餐厅</span>
      </p>

      <!-- Headline -->
      <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-semibold text-charred-brown leading-[1.1]">
        Xinjiang on a plate.
      </h1>

      <!-- Subhead -->
      <p class="text-lg sm:text-xl text-earth-brown max-w-xl mx-auto leading-relaxed">
        Authentic Northern Chinese cuisine, halal always. Roast lamb ribs that fall apart, hand-pulled noodles, dumplings with chili oil that ruins all other chili oils for you. Hidden in Desa Setapak. Worth the drive.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-4">
        <Button href="/menu" variant="primary">See the Menu</Button>
        <Button href="/story#visit" variant="outline">Find Us</Button>
      </div>

      <!-- Handwritten note -->
      <p class="font-accent text-2xl text-earth-brown/70 rotate-[-3deg] mt-8 inline-block">
        since 2016
      </p>
    </div>
  </div>
</section>

<style>
  @keyframes heroSettle {
    from { transform: scale(1.03); }
    to { transform: scale(1); }
  }
</style>
