---
import Container from '../components/Container.astro';
import FadeUp from '../components/FadeUp';
import siteData from '../data/site.json';
---

<section id="visit" class="py-20 lg:py-28 bg-pure-cream">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
      <!-- Map -->
      <FadeUp client:visible delay={0.2}>
        <div class="rounded-2xl overflow-hidden bg-soft-cream h-80 lg:h-auto min-h-[320px]">
          <iframe
            src={siteData.googleMapsEmbedUrl}
            width="100%"
            height="100%"
            style="border:0; min-height: 320px;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Buriram Restaurant location map"
          ></iframe>
        </div>
      </FadeUp>

      <!-- Info -->
      <div class="flex flex-col justify-center">
        <FadeUp client:visible>
          <span class="text-xs font-semibold uppercase tracking-[0.2em] text-thai-chili-red mb-3">Find Us</span>
          <h2 class="font-display text-3xl sm:text-4xl font-semibold text-deep-indigo mb-6">
            Wangsa Maju, Kuala Lumpur
          </h2>
          <div class="space-y-4 text-dusty-slate">
            <div>
              <p class="text-sm font-medium text-deep-indigo mb-1">Hours</p>
              <p>Daily: 11am – 10pm</p>
            </div>
            <div>
              <p class="text-sm font-medium text-deep-indigo mb-1">Phone</p>
              <a href={`tel:${siteData.phone.replace(/\s/g, '')}`} class="hover:text-thai-chili-red transition-colors">
                {siteData.phone}
              </a>
            </div>
            <div>
              <p class="text-sm font-medium text-deep-indigo mb-1">Address</p>
              <p>{siteData.address.full}</p>
            </div>
          </div>
          <div class="mt-8">
            <a
              href={siteData.googleMapsUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-6 py-3 bg-thai-chili-red text-white text-sm font-medium rounded-full hover:bg-thai-chili-red/90 transition-colors"
            >
              Get Directions
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
            </a>
          </div>
        </FadeUp>
      </div>
    </div>
  </Container>
</section>
