---
import Container from '../components/Container.astro';
import FadeUp from '../components/FadeUp';
---

<section class="py-20 lg:py-28 bg-charred-black text-soft-cream">
  <Container>
    <FadeUp client:visible>
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.2em] text-thai-chili-red mb-3">The Space</span>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold leading-tight">
          Small space. Small bowls. Big flavors.
        </h2>
      </div>
    </FadeUp>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 lg:gap-6">
      {['/images/interior-1.svg', '/images/interior-2.svg', '/images/interior-3.svg'].map((src, index) => (
        <FadeUp client:visible delay={index * 0.15}>
          <div class="aspect-[3/4] rounded-xl overflow-hidden bg-soft-cream/10">
            <img
              src={src}
              alt="Interior of Buriram Restaurant"
              class="w-full h-full object-cover opacity-90 hover:opacity-100 transition-opacity duration-700 ease-[cubic-bezier(0.23,1,0.32,1)]"
              loading="lazy"
            />
          </div>
        </FadeUp>
      ))}
    </div>
  </Container>
</section>
