---
import Container from '../components/Container.astro';
import FadeUp from '../components/FadeUp';
---

<section class="py-20 lg:py-28 bg-coal text-warm-sand">
  <Container>
    <FadeUp client:visible>
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="inline-block text-xs font-semibold uppercase tracking-[0.2em] text-xinjiang-red mb-3">The Space</span>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold leading-tight">
          Tucked between car workshops.
        </h2>
      </div>
    </FadeUp>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 lg:gap-6">
      {['/images/interior-1.svg', '/images/interior-2.svg', '/images/interior-3.svg'].map((src, index) => (
        <FadeUp client:visible delay={index * 0.15}>
          <div class="aspect-[3/4] rounded-xl overflow-hidden bg-warm-sand/10">
            <img
              src={src}
              alt="Interior of Lamb Shepherd Restaurant"
              class="w-full h-full object-cover opacity-90 hover:opacity-100 transition-opacity duration-700 ease-[cubic-bezier(0.23,1,0.32,1)]"
              loading="lazy"
            />
          </div>
        </FadeUp>
      ))}
    </div>
    <FadeUp client:visible delay={0.4}>
      <p class="text-center text-warm-sand/60 text-sm mt-8 max-w-lg mx-auto">
        No flashy signage. Just a humble shopfront with a halal Chinese-Muslim restaurant inside. Newly renovated — looks more upmarket now — but the food and the regulars haven't changed.
      </p>
    </FadeUp>
  </Container>
</section>
