---
interface Props {
  href?: string;
  variant?: 'primary' | 'outline' | 'ghost';
  class?: string;
}

const { href, variant = 'primary', class: className = '' } = Astro.props;

const baseStyles = 'inline-flex items-center justify-center px-6 py-3 text-sm font-medium rounded-full transition-[background-color,color,border-color,transform,box-shadow] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] active:scale-[0.98] active:translate-y-0 motion-reduce:transition-none motion-reduce:hover:transform-none';

const variants = {
  primary: 'bg-xinjiang-red text-white hover:bg-xinjiang-red/90 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-xinjiang-red/20',
  outline: 'border-2 border-xinjiang-red text-xinjiang-red hover:bg-xinjiang-red hover:text-white hover:-translate-y-0.5 hover:shadow-lg hover:shadow-xinjiang-red/15',
  ghost: 'text-earth-brown hover:text-charred-brown hover:bg-charred-brown/5',
};

const classes = `${baseStyles} ${variants[variant]} ${className}`;
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button type="button" class={classes}>
    <slot />
  </button>
)}
