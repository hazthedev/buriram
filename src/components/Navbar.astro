---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/menu', label: 'Menu' },
  { href: '/story', label: 'Story' },
];

const currentPath = Astro.url.pathname;
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 bg-soft-cream/70 backdrop-blur-md border-b border-deep-indigo/5 transition-[background-color,backdrop-filter,border-color,box-shadow,transform] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] will-change-transform"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex items-center justify-between h-16 lg:h-20 transition-[height] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]" id="site-nav">
      <!-- Logo -->
      <a href="/" class="flex flex-col items-start group">
        <span class="font-display text-2xl lg:text-3xl font-semibold text-deep-indigo leading-none tracking-tight">
          Buriram
        </span>
        <span class="font-zh text-xs text-dusty-slate leading-none mt-0.5" lang="zh">
          泰国小小碗
        </span>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map(link => (
          <a
            href={link.href}
            data-active={currentPath === link.href}
            class:list={[
              'nav-link relative text-sm font-medium tracking-wide transition-colors duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]',
              currentPath === link.href
                ? 'text-thai-chili-red'
                : 'text-dusty-slate hover:text-deep-indigo'
            ]}
          >
            {link.label}
          </a>
        ))}
        <a
          href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER || '60128331059'}`}
          target="_blank"
          rel="noopener noreferrer"
          class="nav-cta inline-flex items-center gap-2 px-5 py-2.5 bg-thai-chili-red text-white text-sm font-medium rounded-full hover:bg-thai-chili-red/90 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-thai-chili-red/25 transition-[background-color,transform,box-shadow] duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] active:scale-[0.98] active:translate-y-0"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          WhatsApp
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden p-2 text-deep-indigo"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg id="close-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </nav>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden bg-soft-cream border-t border-deep-indigo/5"
  >
    <div class="px-4 py-6 space-y-4">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'block text-base font-medium',
            currentPath === link.href
              ? 'text-thai-chili-red'
              : 'text-dusty-slate'
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href={`https://wa.me/${import.meta.env.PUBLIC_WHATSAPP_NUMBER || '60128331059'}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-5 py-2.5 bg-thai-chili-red text-white text-sm font-medium rounded-full"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        WhatsApp Us
      </a>
    </div>
  </div>
</header>

<style>
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -6px;
    height: 1.5px;
    background-color: currentColor;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 500ms cubic-bezier(0.22, 1, 0.36, 1), background-color 500ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .nav-link:hover::after {
    transform: scaleX(1);
  }
  .nav-link[data-active='true']::after {
    transform: scaleX(1);
    transform-origin: left center;
  }

  #site-header.is-scrolled {
    background-color: color-mix(in srgb, var(--color-soft-cream) 92%, transparent);
    box-shadow: 0 6px 24px -12px rgba(31, 37, 64, 0.18);
    border-bottom-color: color-mix(in srgb, var(--color-deep-indigo) 8%, transparent);
  }
  #site-header.is-scrolled #site-nav {
    height: 3.5rem;
  }
  @media (min-width: 1024px) {
    #site-header.is-scrolled #site-nav {
      height: 4rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-link::after { transition: none; }
    #site-header { transition: none; }
  }
</style>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');
  const closeIcon = document.getElementById('close-icon');

  if (btn && menu && menuIcon && closeIcon) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      menuIcon.classList.toggle('hidden');
      closeIcon.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  }

  const header = document.getElementById('site-header');
  if (header) {
    let ticking = false;
    const update = () => {
      header.classList.toggle('is-scrolled', window.scrollY > 12);
      ticking = false;
    };
    update();
    window.addEventListener('scroll', () => {
      if (!ticking) {
        window.requestAnimationFrame(update);
        ticking = true;
      }
    }, { passive: true });
  }
</script>
