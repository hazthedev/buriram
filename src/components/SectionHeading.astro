---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { eyebrow, title, subtitle, align = 'left' } = Astro.props;

const alignClasses = align === 'center' ? 'text-center' : 'text-left';
---

<div class={`max-w-3xl ${alignClasses}`}>
  {eyebrow && (
    <span class="inline-block text-xs font-semibold uppercase tracking-[0.2em] text-xinjiang-red mb-3">
      {eyebrow}
    </span>
  )}
  <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-semibold text-charred-brown leading-tight">
    {title}
  </h2>
  {subtitle && (
    <p class="mt-4 text-base sm:text-lg text-earth-brown leading-relaxed max-w-xl mx-auto">
      {subtitle}
    </p>
  )}
</div>
